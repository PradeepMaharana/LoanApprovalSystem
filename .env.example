# Environment Configuration Template
# Copy this to .env and update with your values

# API Configuration
API_TITLE=Loan Approval System API
API_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=False

# Database Configuration
DATABASE_URL=mysql://loan_user:loan_password@localhost:3306/loan_approval_system
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=loan_user
DATABASE_PASSWORD=loan_password
DATABASE_NAME=loan_approval_system

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Security Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production-use-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=1
JWT_REFRESH_DAYS=7

# Anthropic API Configuration
ANTHROPIC_API_KEY=sk_live_your_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501", "http://localhost:8502"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Business Rules
MIN_AGE=18
MAX_AGE=100
MIN_CREDIT_SCORE=300
MAX_CREDIT_SCORE=850
MIN_LOAN_AMOUNT=1000
MAX_LOAN_AMOUNT=10000000
MIN_TENURE_MONTHS=3
MAX_TENURE_MONTHS=360

# Risk Thresholds
VERY_LOW_RISK_THRESHOLD=75
LOW_RISK_THRESHOLD=60
MODERATE_RISK_THRESHOLD=40
HIGH_RISK_THRESHOLD=20

# Processing Configuration
PROCESSING_TIME_DAYS=3
PROCESSING_TIME_HOURS=2

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
SENTRY_DSN=

# Email Configuration (for future notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Logging
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Feature Flags
ENABLE_AUDIT_LOGGING=True
ENABLE_CACHING=True
ENABLE_MONITORING=True
ENABLE_RATE_LIMITING=True

# Environment
ENVIRONMENT=development
# Options: development, staging, production
